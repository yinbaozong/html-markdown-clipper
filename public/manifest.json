{
  "manifest_version": 3,
  "name": "网页转 Markdown 下载器",
  "description": "提取网页正文，转换为 Markdown，并将正文原图打包下载。",
  "version": "0.1.0",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "网页转 Markdown",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
